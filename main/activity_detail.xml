<?xml version="1.0" encoding="utf-8"?>
<!-- Detail Screen: Displays full weather report for all entered days -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1628"
    android:padding="20dp">

    <!-- Screen Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📊 Detailed Weather Report"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <!-- Scrollable detail content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp">

        <!-- TextView that displays all days' data -->
        <TextView
            android:id="@+id/txtDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#CCD6F6"
            android:fontFamily="monospace"
            android:background="#112240"
            android:padding="16dp"
            android:lineSpacingMultiplier="1.4" />

    </ScrollView>

    <!-- Back Button -->
    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="← Back to Main Screen"
        android:textColor="#0A1628"
        android:backgroundTint="#64FFDA"
        android:textSize="15sp"
        android:padding="14dp" />

</LinearLayout>
