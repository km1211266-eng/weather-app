<?xml version="1.0" encoding="utf-8"?>
<!-- Splash Screen: App intro with name, student info, logo, and two buttons -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0A1628"
    android:padding="32dp">

    <!-- Weather Logo / Icon -->
    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_launcher_foreground"
        android:layout_marginBottom="16dp"
        android:contentDescription="Weather App Logo" />

    <!-- App Name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Weekly Weather Tracker"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Tagline -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your 7-day forecast companion"
        android:textSize="13sp"
        android:textColor="#7B9FC4"
        android:gravity="center"
        android:layout_marginBottom="40dp" />

    <!-- Divider -->
    <View
        android:layout_width="120dp"
        android:layout_height="1dp"
        android:background="#1E3A5F"
        android:layout_marginBottom="40dp" />

    <!-- Student Info Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#112240"
        android:padding="20dp"
        android:layout_marginBottom="40dp">

        <!-- YOUR NAME — replace this text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student Name: Your Name Here"
            android:textSize="14sp"
            android:textColor="#CCD6F6"
            android:layout_marginBottom="6dp" />

        <!-- YOUR STUDENT NUMBER — replace this text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student Number: ST10XXXXXX"
            android:textSize="14sp"
            android:textColor="#CCD6F6"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Module: IMAD5112"
            android:textSize="14sp"
            android:textColor="#CCD6F6" />
    </LinearLayout>

    <!-- Enter App Button -->
    <Button
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enter App"
        android:textSize="16sp"
        android:textColor="#0A1628"
        android:backgroundTint="#64FFDA"
        android:padding="14dp"
        android:layout_marginBottom="12dp" />

    <!-- Exit App Button -->
    <Button
        android:id="@+id/btnExit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Exit App"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1E3A5F"
        android:padding="14dp" />

</LinearLayout>
